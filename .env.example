# ── Agent Web Stack ──
# Copy this to .env and fill in your values

# ── Camoufox Browser ──
# For auto-update: run scripts/check-camoufox-version.sh periodically
CAMOUFOX_VERSION=135.0.1
CAMOUFOX_RELEASE=beta.24
# Path to camofox-browser project (for Docker build context)
# CAMOFOX_BROWSER_PATH=/home/wastu/projects/camofox-browser

# ── Proxy (residential / home router) ──
PROXY_HOST=10.0.0.2
PROXY_PORT=8888

# ── Firecrawl Shim ──
CAMOFOX_URL=http://camofox-browser:9377
CAMOFOX_FIRECRAWL_FIXED_USER_ID=agent
# Bind to 0.0.0.0 inside Docker container
CAMOFOX_FIRECRAWL_SHIM_HOST=0.0.0.0

# ── SearXNG ──
SEARXNG_SECRET=generate_with_openssl_rand_hex_64
