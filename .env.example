# ── Agent Web Stack ──
# Copy this to .env and fill in your values

# ── Camoufox Browser ──
CAMOUFOX_VERSION=135.0.1
CAMOUFOX_RELEASE=beta.24
# Path to camofox-browser project (for Docker build context)
# CAMOFOX_BROWSER_PATH=/home/wastu/projects/camofox-browser

# ── Proxy (residential / home router) ──
PROXY_HOST=10.0.0.2
PROXY_PORT=8888

# ── Tavily Shim ──
TAVILY_API_KEY=set-your-own-api-key-here

# Domains that always use Camoufox browser
# Comma-separated, matches domain + all subdomains
CAMOFOX_ONLY_SITES=linkedin.com,facebook.com,x.com

# Domains to skip AI summarization (raw content returned as-is)
# Comma-separated, matches domain + all subdomains.
# GitHub (github.com, raw.githubusercontent.com, gist.github.com) always skip.
SKIP_SUMMARY_SITES=

# ── SearXNG ──
SEARXNG_SECRET=generate_with_openssl_rand_hex_64

# Scavio Google Search API (paid, credit-based)
SCAVIO_API_KEY=***
